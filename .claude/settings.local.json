{
  "permissions": {
    "allow": [
      "Read(//private/tmp/**)",
      "Bash(curl -sL https://github.com/cli/cli/releases/download/v2.67.0/gh_2.67.0_macOS_arm64.zip -o gh.zip)",
      "Bash(unzip -o gh.zip -d gh_extract)",
      "Bash(GH=/tmp/gh_extract/gh_2.67.0_macOS_arm64/bin/gh)",
      "Bash(chmod +x \"$GH\")",
      "Bash($GH --version)",
      "Bash($GH auth:*)",
      "Bash(git init:*)",
      "Bash(git add:*)"
    ]
  }
}
